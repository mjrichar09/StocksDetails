# ── E*Trade ───────────────────────────────────────────────────────────────────
# Get these from https://developer.etrade.com → My Applications
ETRADE_CONSUMER_KEY=your_consumer_key_here
ETRADE_CONSUMER_SECRET=your_consumer_secret_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and service-role key — Settings → API in the Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
# Anon (public) key — used client-side in frontend/index.html
SUPABASE_ANON_KEY=your_anon_key_here
